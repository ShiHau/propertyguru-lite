# App Settings
APP_NAME=PropertyGuru Lite
APP_ENVIRONMENT=development
# Options: "development" or "production"
# - development: uses SQLite (file: ./data/app.db) and in-memory MockRedis
# - production: uses PostgreSQL and real Redis (Docker Compose)

# ===== DEVELOPMENT (APP_ENVIRONMENT=development) =====
# No additional config needed - SQLite and MockRedis work out of the box

# ===== PRODUCTION (APP_ENVIRONMENT=production) =====
# PostgreSQL Configuration
POSTGRES_USER=app_user
POSTGRES_PASSWORD=secure_local_password
POSTGRES_DB=app_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Frontend/Backend API URL
FRONTEND_BACKEND_BASE_URL=http://backend:8000

# JWT Authentication
JWT_SECRET_KEY=dev-change-me-in-production
JWT_ALGORITHM=HS256

# Assignment Strategy
ASSIGNMENT_STRATEGY=round_robin_load_aware
